<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.epf.pointage.ui.AssignationFormController"
      spacing="14" prefWidth="680"
      stylesheets="@../css/styles.css">
    <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

    <Label text="Nouvelle assignation de cours" styleClass="page-title"/>
    <Label fx:id="lblErreur" text="" styleClass="error-label"
           visible="false" managed="false" wrapText="true"/>

    <GridPane hgap="14" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="35"/>
            <ColumnConstraints percentWidth="65"/>
        </columnConstraints>

        <Label text="Professeur *" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
        <ComboBox fx:id="comboProfesseur" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Cours *" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
        <ComboBox fx:id="comboCours" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Salle" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
        <ComboBox fx:id="comboSalle" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Année académique *" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="fieldAnneeAcademique" GridPane.rowIndex="3" GridPane.columnIndex="1"
                   styleClass="form-input" promptText="ex: 2025-2026"/>

        <Label text="Heures prévues" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="fieldHeuresPrevues" GridPane.rowIndex="4" GridPane.columnIndex="1"
                   styleClass="form-input" promptText="ex: 60"/>

        <Label text="Jour de la semaine *" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label"/>
        <ComboBox fx:id="comboJour" GridPane.rowIndex="5" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Heure début (HH:mm) *" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="fieldHeureDebut" GridPane.rowIndex="6" GridPane.columnIndex="1"
                   styleClass="form-input" promptText="ex: 08:00"/>

        <Label text="Heure fin (HH:mm) *" GridPane.rowIndex="7" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="fieldHeureFin" GridPane.rowIndex="7" GridPane.columnIndex="1"
                   styleClass="form-input" promptText="ex: 10:00"/>

        <Label text="Fréquence *" GridPane.rowIndex="8" GridPane.columnIndex="0" styleClass="form-label"/>
        <ComboBox fx:id="comboFrequence" GridPane.rowIndex="8" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Date début semestre *" GridPane.rowIndex="9" GridPane.columnIndex="0" styleClass="form-label"/>
        <DatePicker fx:id="dateDebutSemestre" GridPane.rowIndex="9" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Date fin semestre *" GridPane.rowIndex="10" GridPane.columnIndex="0" styleClass="form-label"/>
        <DatePicker fx:id="dateFinSemestre" GridPane.rowIndex="10" GridPane.columnIndex="1" maxWidth="Infinity"/>
    </GridPane>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleAnnuler" styleClass="btn-secondary"/>
        <Button fx:id="btnSauvegarder" text="✅ Planifier" onAction="#handleSauvegarder" styleClass="btn-primary"/>
    </HBox>
</VBox>