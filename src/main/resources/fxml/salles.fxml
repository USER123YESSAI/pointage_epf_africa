<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="sn.epf.pointage.ui.SallesController"
      spacing="12" stylesheets="@../css/styles.css" styleClass="page-container">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <Label text="Gestion des Salles" styleClass="page-title"/>

    <HBox spacing="8">
        <Button fx:id="btnAdd" text="➕ Nouvelle salle" onAction="#handleAdd" styleClass="btn-primary"/>
        <Button fx:id="btnRefresh" text="⟳ Rafraîchir" onAction="#handleRefresh"/>
    </HBox>

    <TableView fx:id="tableSalles" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNom" text="Nom" prefWidth="220"/>
            <TableColumn fx:id="colBatiment" text="Bâtiment" prefWidth="160"/>
            <TableColumn fx:id="colCapacite" text="Capacité" prefWidth="100"/>
            <TableColumn fx:id="colEquipements" text="Équipements" prefWidth="300"/>
        </columns>
    </TableView>
</VBox>
