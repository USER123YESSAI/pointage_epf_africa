<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="sn.epf.pointage.ui.CoursFormController"
      spacing="10" stylesheets="@../css/styles.css" styleClass="page-container">
    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
    <Label text="Nouveau cours" styleClass="page-title" fx:id="lblTitre"/>

    <GridPane hgap="8" vgap="8">
        <Label text="Code" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldCode" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Intitulé" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldIntitule" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Filière" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldFiliere" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Niveau" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldNiveau" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Volume horaire" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldVolume" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Semestre" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldSemestre" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Description" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextArea fx:id="fieldDescription" GridPane.rowIndex="6" GridPane.columnIndex="1" prefRowCount="3"/>
    </GridPane>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancel"/>
        <Button text="Enregistrer" onAction="#handleSave" styleClass="btn-primary"/>
    </HBox>
</VBox>
